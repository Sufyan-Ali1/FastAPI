# .env.example - a COMMITTED template (no real secrets).
# Copy to .env (which is git-ignored) and fill in real values:
#     cp .env.example .env
#
# Real environment variables OVERRIDE these .env values.

APP_NAME="Lesson 45 - Config API (dev)"
ENVIRONMENT=dev
DEBUG=true
PORT=8000
ALLOWED_ORIGINS=["http://localhost:3000"]

# Required (the app will not start without these):
DATABASE_URL=sqlite:///./dev.db
SECRET_KEY=replace-with-a-strong-random-secret
